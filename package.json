{
  "name": "pfc-course-advisor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --exec \"node --loader ts-node/esm\" src/server.ts",
    "migrate": "node --loader ts-node/esm src/db.ts migrate",
    "seed": "node --loader ts-node/esm src/db.ts seed",
    "reset:demo": "node --loader ts-node/esm src/db.ts reset-demo",
    "build": "tsc",
    "test": "node --loader ts-node/esm ./node_modules/mocha/bin/mocha.js \"test/**/*.test.ts\"",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "serverless-http": "^3.0.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.17",
    "@types/mocha": "^10.0.0",
    "@types/node": "^20.16.0",
    "mocha": "^10.2.0",
    "nodemon": "^2.0.22",
    "ts-node": "^10.9.1",
    "typescript": "^5.5.4"
  },
  "engines": {
    "node": ">=20"
  }
}
